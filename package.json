{
  "name": "@advantacode/brander",
  "version": "0.0.1",
  "description": "AdvantaCode Design System Brand Generator",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "bin": {
    "advantacode-brander": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "node --import tsx/esm dist/index.js",
    "tokens": "tsx src/generate-tokens.ts",
    "prepack": "npm run build",
    "brand:generate": "advantacode-brander --out src/generated/brand"
  },
  "license": "MIT",
  "author": "Anthony Penn",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "culori": "^4.0.2",
    "dotenv": "^17.3.1",
    "tsx": "^4.0.0"
  }
}
